<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.micro.platform.system.mapper.SysTodoTagRelationMapper">

    <!-- 根据待办 ID 获取标签列表 -->
    <select id="selectTagsByTodoId" resultType="com.micro.platform.system.entity.SysTodoTag">
        SELECT t.*
        FROM sys_todo_tag t
        INNER JOIN sys_todo_tag_relation r ON t.tag_id = r.tag_id
        WHERE r.todo_id = #{todoId}
        AND t.deleted = 0
        ORDER BY t.sort ASC
    </select>

    <!-- 根据标签 ID 获取关联列表 -->
    <select id="selectRelationsByTagId" resultType="com.micro.platform.system.entity.SysTodoTagRelation">
        SELECT * FROM sys_todo_tag_relation
        WHERE tag_id = #{tagId}
    </select>

    <!-- 批量插入关联关系 -->
    <insert id="batchInsert">
        INSERT INTO sys_todo_tag_relation (todo_id, tag_id, create_time) VALUES
        <foreach collection="relations" item="relation" separator=",">
            (#{relation.todoId}, #{relation.tagId}, NOW())
        </foreach>
    </insert>

    <!-- 删除待办的所有标签关联 -->
    <delete id="deleteByTodoId">
        DELETE FROM sys_todo_tag_relation WHERE todo_id = #{todoId}
    </delete>

</mapper>