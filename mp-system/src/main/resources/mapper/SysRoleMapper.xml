<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.micro.platform.system.mapper.SysRoleMapper">

    <!-- 根据用户 ID 查询角色 ID 列表 -->
    <select id="selectRoleIdsByUserId" resultType="java.lang.Long">
        SELECT r.role_id
        FROM sys_role r
        INNER JOIN sys_user_role ur ON r.role_id = ur.role_id
        WHERE ur.user_id = #{userId} AND r.deleted = 0
    </select>

    <!-- 根据角色 ID 查询菜单 ID 列表 -->
    <select id="selectMenuIdsByRoleId" resultType="java.lang.Long">
        SELECT rm.menu_id
        FROM sys_role_menu rm
        WHERE rm.role_id = #{roleId}
    </select>

    <!-- 删除角色的菜单关联 -->
    <delete id="deleteRoleMenus">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 批量插入角色菜单关联 -->
    <insert id="batchInsertRoleMenus">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId})
        </foreach>
    </insert>

</mapper>