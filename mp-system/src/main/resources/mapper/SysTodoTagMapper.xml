<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.micro.platform.system.mapper.SysTodoTagMapper">

    <!-- 获取用户的标签列表 -->
    <select id="selectByUserId" resultType="com.micro.platform.system.entity.SysTodoTag">
        SELECT * FROM sys_todo_tag
        WHERE user_id = #{userId} OR user_id IS NULL
        AND deleted = 0
        ORDER BY sort ASC, create_time DESC
    </select>

</mapper>