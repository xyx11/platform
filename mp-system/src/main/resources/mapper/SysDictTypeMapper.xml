<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.micro.platform.system.mapper.SysDictTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.micro.platform.system.entity.SysDictType">
        <id column="dict_id" property="dictId"/>
        <result column="dict_name" property="dictName"/>
        <result column="dict_type" property="dictType"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        dict_id, dict_name, dict_type, status, remark, create_by, create_time, update_by, update_time, deleted
    </sql>

    <!-- 分页查询字典类型列表 -->
    <select id="selectPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_dict_type
        <where>
            deleted = 0
            <if test="dict.dictName != null and dict.dictName != ''">
                AND dict_name LIKE CONCAT('%', #{dict.dictName}, '%')
            </if>
            <if test="dict.dictType != null and dict.dictType != ''">
                AND dict_type LIKE CONCAT('%', #{dict.dictType}, '%')
            </if>
            <if test="dict.status != null">
                AND status = #{dict.status}
            </if>
        </where>
        ORDER BY dict_id DESC
    </select>

    <!-- 查询所有正常的字典类型 -->
    <select id="selectAllNormal" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_dict_type
        WHERE deleted = 0 AND status = 1
        ORDER BY dict_id DESC
    </select>

</mapper>